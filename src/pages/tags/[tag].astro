---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Badge from "@/components/ui/Badge.astro";
import { comparePostsByPinnedAndDate } from "@/utils/posts";
import { normalizeTag, slugifyTag } from "@/utils/tags";

export async function getStaticPaths() {
    const entries = await getCollection("post");

    const tagMap = new Map<string, { label: string; slug: string }>();

    for (const entry of entries) {
        for (const tag of entry.data.tags) {
            const key = normalizeTag(tag);
            if (tagMap.has(key)) continue;

            tagMap.set(key, {
                label: tag,
                slug: slugifyTag(tag),
            });
        }
    }

    return Array.from(tagMap.values()).map((tag) => ({
        params: { tag: tag.slug },
        props: { tagLabel: tag.label, normalizedTag: normalizeTag(tag.label) },
    }));
}

const { tagLabel, normalizedTag } = Astro.props;

const entries = await getCollection("post", (entry) =>
    entry.data.tags.some((tag) => normalizeTag(tag) === normalizedTag),
);

const posts = entries
    .map((entry) => ({
        id: entry.id,
        slug: entry.id,
        readTime: Math.max(1, Math.ceil(entry.body!.split(/\s+/).length / 200)),
        ...entry.data,
    }))
    .sort(comparePostsByPinnedAndDate);

const pinnedPosts = posts.filter((post) => post.pinned);
const regularPosts = posts.filter((post) => !post.pinned);
const postHrefForCurrentTag = (slug: string) =>
    `/posts/${slug}?from=tag&tag=${Astro.params.tag}`;
---

<Layout
    title={`#${tagLabel} | Serene Ink`}
    description={`Posts tagged with ${tagLabel}.`}
>
    <main class="page pb-16 space-y-8">
        <section class="space-y-3 max-w-3xl">
            <a
                href="/tags"
                class="text-sm font-medium text-muted-foreground hover:text-primary transition-colors inline-flex items-center gap-2"
            >
                <span>←</span> All tags
            </a>
            <h1 class="text-4xl md:text-5xl leading-tight">#{tagLabel}</h1>
            <p class="text-lg text-muted-foreground">
                {posts.length} {posts.length === 1 ? "post" : "posts"} in this
                topic.
            </p>
        </section>

        {
            pinnedPosts.length > 0 && (
                <section class="space-y-4">
                    <h2 class="text-2xl">Pinned</h2>
                    <section class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        {pinnedPosts.map((post) => (
                            <article class="border border-border rounded-lg p-5 bg-card/30 hover:bg-muted/70 transition-colors duration-300 flex flex-col gap-4">
                                <div class="space-y-3">
                                    <div class="flex items-center justify-between gap-3 text-xs text-muted-foreground">
                                        <span>{post.date}</span>
                                        <span>{post.readTime} min read</span>
                                    </div>
                                    <a href={postHrefForCurrentTag(post.slug)}>
                                        <h2 class="text-2xl leading-tight hover:text-primary transition-colors">
                                            {post.title}
                                        </h2>
                                    </a>
                                    <p class="text-muted-foreground">{post.frontmatter}</p>
                                </div>
                                <div class="flex flex-wrap gap-2 pt-1">
                                    {post.tags.map((tag) => (
                                        <Badge
                                            content={tag}
                                            href={`/tags/${slugifyTag(tag)}`}
                                        />
                                    ))}
                                </div>
                            </article>
                        ))}
                    </section>
                </section>
            )
        }

        {
            regularPosts.length > 0 ? (
                <section class="space-y-4">
                    {pinnedPosts.length > 0 && <h2 class="text-2xl">Timeline</h2>}
                    <section class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        {regularPosts.map((post) => (
                        <article class="border border-border rounded-lg p-5 bg-card/30 hover:bg-muted/70 transition-colors duration-300 flex flex-col gap-4">
                            <div class="space-y-3">
                                <div class="flex items-center justify-between gap-3 text-xs text-muted-foreground">
                                    <span>{post.date}</span>
                                    <span>{post.readTime} min read</span>
                                </div>
                                <a href={postHrefForCurrentTag(post.slug)}>
                                    <h2 class="text-2xl leading-tight hover:text-primary transition-colors">
                                        {post.title}
                                    </h2>
                                </a>
                                <p class="text-muted-foreground">{post.frontmatter}</p>
                            </div>
                            <div class="flex flex-wrap gap-2 pt-1">
                                {post.tags.map((tag) => (
                                    <Badge
                                        content={tag}
                                        href={`/tags/${slugifyTag(tag)}`}
                                    />
                                ))}
                            </div>
                        </article>
                        ))}
                    </section>
                </section>
            ) : posts.length > 0 ? (
                <section class="border border-dashed border-border rounded-lg p-8 text-muted-foreground">
                    No timeline posts for this tag yet.
                </section>
            ) : (
                <section class="border border-dashed border-border rounded-lg p-8 text-muted-foreground">
                    No posts found for this tag.
                </section>
            )
        }
    </main>
</Layout>