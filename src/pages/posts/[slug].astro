---
import { getCollection, render } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Badge from "@/components/ui/Badge.astro";
import MobileTOC from "@/components/posts/MobileTOC.astro";
import DesktopTOC from "@/components/posts/DesktopTOC.astro";
import { Image } from "astro:assets";
import { slugifyTag } from "@/utils/tags";
import { comparePostsByPinnedAndDate } from "@/utils/posts";

export async function getStaticPaths() {
    const posts = await getCollection("post");
    return posts.map((post) => ({
        params: { slug: post.id },
        props: { post },
    }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const allPosts = await getCollection("post");
const orderedPosts = [...allPosts].sort((a, b) =>
    comparePostsByPinnedAndDate(a.data, b.data),
);

const currentIndex = orderedPosts.findIndex((entry) => entry.id === post.id);
const prevPost = currentIndex > 0 ? orderedPosts[currentIndex - 1] : undefined;
const nextPost =
    currentIndex >= 0 && currentIndex < orderedPosts.length - 1
        ? orderedPosts[currentIndex + 1]
        : undefined;

const buildDefaultPostHref = (slug: string) => `/posts/${slug}?from=writing`;
const navigationData = orderedPosts.map((entry) => ({
    slug: entry.id,
    title: entry.data.title,
    tags: entry.data.tags.map((tag) => slugifyTag(tag)),
}));

const readTime = Math.max(1, Math.ceil(post.body!.split(/\s+/).length / 200));

// date is assuming to be MM/DD/YYYY
const dateParts = post.data.date.split("/");
const dateObj = new Date(
    Date.UTC(
        Number(dateParts[2]),
        Number(dateParts[0]) - 1,
        Number(dateParts[1]),
    ),
);

const dateFormatted = dateObj.toLocaleDateString("en-US", {
    timeZone: "UTC",
    month: "short",
    day: "numeric",
    year: "numeric",
});

const isoDate = dateObj.toISOString();

const updatedIsoDate = post.data.updatedDate
    ? (() => {
          const updatedDateParts = post.data.updatedDate.split("/");
          return new Date(
              Date.UTC(
                  Number(updatedDateParts[2]),
                  Number(updatedDateParts[0]) - 1,
                  Number(updatedDateParts[1]),
              ),
          ).toISOString();
      })()
    : isoDate;

const ogImage = post.data.image?.src;
const absolutePageUrl = Astro.site
    ? new URL(Astro.url.pathname, Astro.site).href
    : Astro.url.href;
const absoluteOgImage = ogImage
    ? new URL(ogImage, Astro.site || Astro.url.origin).href
    : undefined;

const articleSchema = {
    "@type": "BlogPosting",
    headline: post.data.title,
    description: post.data.frontmatter,
    image: absoluteOgImage ? [absoluteOgImage] : undefined,
    datePublished: isoDate,
    dateModified: updatedIsoDate,
    inLanguage: "en-US",
    keywords: post.data.tags,
    articleSection: post.data.tags[0],
    author: {
        "@type": "Person",
        name: "infinInk",
    },
    publisher: {
        "@type": "Organization",
        name: "infinInk",
    },
    mainEntityOfPage: absolutePageUrl,
    url: absolutePageUrl,
};

const breadcrumbSchema = {
    "@type": "BreadcrumbList",
    itemListElement: [
        {
            "@type": "ListItem",
            position: 1,
            name: "Home",
            item: Astro.site
                ? new URL("/", Astro.site).href
                : new URL("/", Astro.url.origin).href,
        },
        {
            "@type": "ListItem",
            position: 2,
            name: "Writing",
            item: Astro.site
                ? new URL("/writing", Astro.site).href
                : new URL("/writing", Astro.url.origin).href,
        },
        {
            "@type": "ListItem",
            position: 3,
            name: post.data.title,
            item: absolutePageUrl,
        },
    ],
};
---

<Layout
    title={`${post.data.title} | infinInk`}
    description={post.data.frontmatter}
    type="article"
    image={ogImage}
    canonical={post.data.canonical}
    noindex={post.data.noindex}
    keywords={post.data.tags}
    publishedTime={isoDate}
    modifiedTime={updatedIsoDate}
    author="infinInk"
    section={post.data.tags[0]}
    tags={post.data.tags}
    jsonLd={[articleSchema, breadcrumbSchema]}
>
    <div class="fixed top-0 left-0 w-full z-50 bg-transparent">
        <div
            id="progress-bar"
            class="h-0.75 bg-primary transition-all duration-150 ease-out"
            style="width: 0%"
        >
        </div>
    </div>
    <main class="page pb-20 mt-10 relative">
        <div class="mb-10 w-full">
            <a
                href="/writing"
                class="post-back-link text-sm font-medium text-muted-foreground hover:text-primary transition-colors flex items-center gap-2"
            >
                <span>←</span> <span class="post-back-text">Back to writing</span>
            </a>
        </div>

        <article class="w-full max-w-full">
            <header class="mb-14 lg:mb-20">
                <h1
                    class="text-4xl md:text-5xl lg:text-5xl font-bold tracking-tight mb-6 text-foreground leading-tight"
                >
                    {post.data.title}
                </h1>
                <div
                    class="flex items-center gap-2 text-sm text-muted-foreground mb-6 flex-wrap"
                >
                    <time datetime={isoDate}>{dateFormatted}</time>
                    <span>·</span>
                    <span>{readTime} min read</span>
                    <span>·</span>
                    <div class="flex gap-2 flex-wrap">
                        {
                            post.data.tags.map((tag: string) => (
                                <Badge
                                    content={tag}
                                    href={`/tags/${slugifyTag(tag)}`}
                                />
                            ))
                        }
                    </div>
                </div>
                {
                    post.data.image && (
                        <Image
                            src={post.data.image}
                            alt={post.data.title}
                            class="w-full h-auto rounded-xl mt-8 object-cover aspect-video border border-border"
                        />
                    )
                }
            </header>
        </article>

        <div class="flex flex-col lg:flex-row gap-10 relative">
            <div class="flex-1 w-full max-w-full">
                <div class="prose-blog">
                    <div class="drop-cap">
                        <Content />
                    </div>
                </div>
            </div>

            {headings.length > 0 && <DesktopTOC headings={headings} />}
        </div>

        <div class="mt-20 pt-10 border-t border-border flex justify-start">
            <div class="w-full space-y-8">
                <section id="post-nav-section" class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <a
                        id="post-prev-link"
                        href={prevPost ? buildDefaultPostHref(prevPost.id) : "#"}
                        class:list={{
                            "border border-border rounded-lg p-4 bg-card/30 hover:bg-muted/70 transition-colors": true,
                            hidden: !prevPost,
                        }}
                    >
                        <p class="text-xs uppercase tracking-widest text-muted-foreground mb-2">
                            Previous
                        </p>
                        <p id="post-prev-title" class="text-lg leading-snug hover:text-primary transition-colors">
                            {prevPost?.data.title}
                        </p>
                    </a>

                    <a
                        id="post-next-link"
                        href={nextPost ? buildDefaultPostHref(nextPost.id) : "#"}
                        class:list={{
                            "border border-border rounded-lg p-4 bg-card/30 hover:bg-muted/70 transition-colors text-left md:text-right md:col-start-2": true,
                            hidden: !nextPost,
                        }}
                    >
                        <p class="text-xs uppercase tracking-widest text-muted-foreground mb-2">
                            Next
                        </p>
                        <p id="post-next-title" class="text-lg leading-snug hover:text-primary transition-colors">
                            {nextPost?.data.title}
                        </p>
                    </a>
                </section>

                <a
                    href="/writing"
                    class="post-back-link text-sm font-medium text-muted-foreground hover:text-primary transition-colors flex items-center gap-2"
                >
                    <span>←</span> <span class="post-back-text">Back to writing</span>
                </a>
            </div>
        </div>
    </main>

    <script
        id="post-navigation-data"
        type="application/json"
        set:html={JSON.stringify({ currentSlug: post.id, posts: navigationData })}
    />

    {headings.length > 0 && <MobileTOC headings={headings} />}
    <script is:inline>
        let onScroll = null;
        let observer = null;

        document.addEventListener(
            "astro:before-swap",
            () => {
                if (onScroll) {
                    window.removeEventListener("scroll", onScroll);
                    onScroll = null;
                }
                if (observer) {
                    observer.disconnect();
                    observer = null;
                }
            },
            { once: true },
        );

        document.addEventListener("astro:page-load", () => {
            const applyContextNavigation = () => {
                const navDataScript = document.getElementById(
                    "post-navigation-data",
                );
                if (!navDataScript?.textContent) return;

                const payload = JSON.parse(navDataScript.textContent);
                if (!payload?.currentSlug || !Array.isArray(payload.posts))
                    return;

                const params = new URLSearchParams(window.location.search);
                const from = params.get("from");
                const tag = params.get("tag");

                let posts = payload.posts;
                let contextQuery = "?from=writing";
                let backHref = "/writing";
                let backText = "Back to writing";

                if (from === "tag" && tag) {
                    posts = posts.filter((p) => p.tags.includes(tag));
                    contextQuery = `?from=tag&tag=${encodeURIComponent(tag)}`;
                    backHref = `/tags/${tag}`;
                    backText = `Back to #${tag}`;
                }

                const index = posts.findIndex(
                    (entry) => entry.slug === payload.currentSlug,
                );

                const prev = index > 0 ? posts[index - 1] : null;
                const next =
                    index >= 0 && index < posts.length - 1
                        ? posts[index + 1]
                        : null;

                document.querySelectorAll(".post-back-link").forEach((el) => {
                    if (!(el instanceof HTMLAnchorElement)) return;
                    const link = el;
                    link.href = backHref;
                    const label = link.querySelector(".post-back-text");
                    if (label) label.textContent = backText;
                });

                const prevLink = document.getElementById("post-prev-link");
                const prevTitle = document.getElementById("post-prev-title");

                if (
                    prevLink instanceof HTMLAnchorElement &&
                    prevTitle instanceof HTMLElement
                ) {
                    if (prev) {
                        prevLink.href = `/posts/${prev.slug}${contextQuery}`;
                        prevTitle.textContent = prev.title;
                        prevLink.classList.remove("hidden");
                    } else {
                        prevLink.classList.add("hidden");
                    }
                }

                const nextLink = document.getElementById("post-next-link");
                const nextTitle = document.getElementById("post-next-title");

                if (
                    nextLink instanceof HTMLAnchorElement &&
                    nextTitle instanceof HTMLElement
                ) {
                    if (next) {
                        nextLink.href = `/posts/${next.slug}${contextQuery}`;
                        nextTitle.textContent = next.title;
                        nextLink.classList.remove("hidden");
                    } else {
                        nextLink.classList.add("hidden");
                    }
                }

                const navSection = document.getElementById("post-nav-section");
                if (navSection) {
                    navSection.classList.toggle("hidden", !prev && !next);
                }
            };

            applyContextNavigation();

            onScroll = () => {
                const winScroll =
                    document.body.scrollTop ||
                    document.documentElement.scrollTop;
                const height =
                    document.documentElement.scrollHeight -
                    document.documentElement.clientHeight;
                const scrolled = height <= 0 ? 100 : (winScroll / height) * 100;
                const progressBar = document.getElementById("progress-bar");
                if (progressBar) {
                    progressBar.style.width = scrolled + "%";
                }
            };

            window.addEventListener("scroll", onScroll);

            const activeLiClasses = [
                "border-l-2",
                "border-primary",
                "-ml-[1px]",
            ];
            const activeLinkClasses = ["text-foreground", "font-medium"];

            const activeHeadings = new Set();

            observer = new IntersectionObserver(
                (entries) => {
                    entries.forEach((entry) => {
                        const id = entry.target.getAttribute("id");
                        if (entry.isIntersecting) {
                            activeHeadings.add(id);
                        } else {
                            activeHeadings.delete(id);
                        }
                    });

                    const headers = Array.from(
                        document.querySelectorAll("h2, h3, h4"),
                    );
                    const firstActive = headers.find((h) =>
                        activeHeadings.has(h.getAttribute("id")),
                    );

                    if (firstActive) {
                        const id = firstActive.getAttribute("id");
                        const desktopLink = document.querySelector(
                            `aside a[href="#${id}"]`,
                        );
                        const mobileLink = document.querySelector(
                            `#mobile-toc-menu a[href="#${id}"]`,
                        );

                        document.querySelectorAll("aside li").forEach((el) => {
                            el.classList.remove(...activeLiClasses);
                            const a = el.querySelector("a");
                            if (a) {
                                a.classList.remove(...activeLinkClasses);
                                a.classList.add("text-muted-foreground");
                            }
                        });

                        document
                            .querySelectorAll("#mobile-toc-menu li")
                            .forEach((el) => {
                                el.classList.remove(...activeLiClasses);
                                const a = el.querySelector("a");
                                if (a) {
                                    a.classList.remove(...activeLinkClasses);
                                    a.classList.add("text-muted-foreground");
                                }
                            });

                        if (desktopLink) {
                            const asideLi = desktopLink.parentElement;
                            asideLi.classList.add(...activeLiClasses);
                            desktopLink.classList.add(...activeLinkClasses);
                            desktopLink.classList.remove(
                                "text-muted-foreground",
                            );
                        }

                        if (mobileLink) {
                            const mobileLi = mobileLink.parentElement;
                            mobileLi.classList.add(...activeLiClasses);
                            mobileLink.classList.add(...activeLinkClasses);
                            mobileLink.classList.remove(
                                "text-muted-foreground",
                            );
                        }
                    }
                },
                { rootMargin: "0px 0px -80% 0px" },
            );

            document.querySelectorAll("h2, h3, h4").forEach((header) => {
                observer.observe(header);
            });
        });
    </script>
</Layout>
