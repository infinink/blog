---
import Layout from "@/layouts/Layout.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import { projects } from "@/data/projects";

const baseUrl = Astro.site || new URL(Astro.url.origin);
const homePageUrl = new URL("/", baseUrl).href;
const projectsPageUrl = new URL("/projects", baseUrl).href;

const projectsCollectionSchema = {
    "@type": "CollectionPage",
    name: "infinInk Projects",
    description: "A curated list of projects built by infinInk.",
    url: projectsPageUrl,
};

const projectsItemListSchema = {
    "@type": "ItemList",
    name: "Projects",
    itemListElement: projects.map((project, index) => ({
        "@type": "ListItem",
        position: index + 1,
        name: project.title,
        url: project.link,
    })),
};

const breadcrumbSchema = {
    "@type": "BreadcrumbList",
    itemListElement: [
        {
            "@type": "ListItem",
            position: 1,
            name: "Home",
            item: homePageUrl,
        },
        {
            "@type": "ListItem",
            position: 2,
            name: "Projects",
            item: projectsPageUrl,
        },
    ],
};
---

<Layout
    title="Projects | infinInk"
    description="A curated list of projects built by infinInk."
    keywords={["projects", "portfolio", "backend", "flutter", "infinInk"]}
    jsonLd={[projectsCollectionSchema, projectsItemListSchema, breadcrumbSchema]}
>
    <main class="page flex flex-col gap-8 pb-16">
        <section class="space-y-4 max-w-3xl">
            <span class="uppercase text-primary font-medium tracking-widest text-xs"
                >work showcase</span
            >
            <h1 class="text-4xl md:text-5xl leading-tight">Projects</h1>
            <p class="text-lg text-muted-foreground">
                Things I built while learning in public — focused on practical
                software and useful systems.
            </p>
        </section>

        <section class="flex flex-col gap-4">
            {
                projects.map((project) => (
                    <ProjectCard
                        title={project.title}
                        description={project.description}
                        url={project.link}
                        techStack={project.techStack}
                    />
                ))
            }
        </section>
    </main>
</Layout>
