---
import WritingList from "@/components/Writing.astro";
import Layout from "@/layouts/Layout.astro";

const baseUrl = Astro.site || new URL(Astro.url.origin);
const homePageUrl = new URL("/", baseUrl).href;
const writingPageUrl = new URL("/writing", baseUrl).href;

const writingCollectionSchema = {
    "@type": "CollectionPage",
    name: "infinInk Writing",
    description: "All writing posts from infinInk.",
    url: writingPageUrl,
};

const breadcrumbSchema = {
    "@type": "BreadcrumbList",
    itemListElement: [
        {
            "@type": "ListItem",
            position: 1,
            name: "Home",
            item: homePageUrl,
        },
        {
            "@type": "ListItem",
            position: 2,
            name: "Writing",
            item: writingPageUrl,
        },
    ],
};
---

<Layout
    title="Writing | infinInk"
    description="Browse all posts on infinInk."
    image="/images/home.webp"
    keywords={["writing", "posts", "backend", "programming", "infinInk"]}
    jsonLd={[writingCollectionSchema, breadcrumbSchema]}
>
    <WritingList />
</Layout>
