---
import "../styles/global.css";
import { Moon, Sun, Braces, Search, Rss, Accessibility, X } from "@lucide/astro";
import { ClientRouter } from "astro:transitions";

interface Props {
    title?: string;
    description?: string;
    type?: string;
    image?: string;
    canonical?: string;
    noindex?: boolean;
    keywords?: string[];
    publishedTime?: string;
    modifiedTime?: string;
    author?: string;
    section?: string;
    tags?: string[];
    jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
    title = "infinInk",
    description = "Notes from someone still figuring it out — shipped anyway.",
    type = "website",
    image,
    canonical,
    noindex = false,
    keywords = [],
    publishedTime,
    modifiedTime,
    author = "infinInk",
    section,
    tags = [],
    jsonLd,
} = Astro.props;

const siteOrigin = Astro.site || new URL(Astro.url.origin);
const canonicalURL = canonical
    ? new URL(canonical, siteOrigin)
    : new URL(Astro.url.pathname, siteOrigin);
const resolvedImage = image ? new URL(image, siteOrigin).href : undefined;
const robotsContent = noindex
    ? "noindex, nofollow"
    : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1";
const metaKeywords = keywords
    .map((value) => value.trim())
    .filter(Boolean)
    .join(", ");
const websiteSchema = {
    "@type": "WebSite",
    name: "infinInk",
    url: new URL("/", siteOrigin).href,
    inLanguage: "en-US",
};
const jsonLdBlocks = [websiteSchema, ...(Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [])]
    .filter(Boolean)
    .map((schema) => ({
        "@context": "https://schema.org",
        ...schema,
    }));

const normalize = (p: string) => p.replace(/\/+$/, "") || "/";

const isOnCurrentPath = (path: string) => {
    return normalize(Astro.url.pathname) === normalize(path);
};
---

<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <meta name="description" content={description} />
        <meta name="robots" content={robotsContent} />
        <meta name="googlebot" content={robotsContent} />
        {metaKeywords && <meta name="keywords" content={metaKeywords} />}
        <ClientRouter />
        <link rel="sitemap" href="/sitemap-index.xml" />
        <link rel="canonical" href={canonicalURL.href} />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />

        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:url" content={canonicalURL.href} />
        <meta property="og:type" content={type} />
        <meta property="og:site_name" content="infinInk" />
        <meta property="og:locale" content="en_US" />
        {resolvedImage && <meta property="og:image" content={resolvedImage} />}
        {resolvedImage && <meta name="twitter:image" content={resolvedImage} />}
        {
            type === "article" && publishedTime && (
                <meta property="article:published_time" content={publishedTime} />
            )
        }
        {
            type === "article" && modifiedTime && (
                <meta property="article:modified_time" content={modifiedTime} />
            )
        }
        {type === "article" && <meta property="article:author" content={author} />}
        {type === "article" && section && <meta property="article:section" content={section} />}
        {
            type === "article" &&
                tags.map((tag) => <meta property="article:tag" content={tag} />)
        }
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />

        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        <link
            rel="alternate"
            type="application/rss+xml"
            title="infinInk"
            href={new URL("feed.xml", siteOrigin)}
        />
        {
            jsonLdBlocks.map((schema) => (
                <script
                    type="application/ld+json"
                    set:html={JSON.stringify(schema)}
                />
            ))
        }
        <script is:inline>
            const setDarkMode = () => {
                const theme = (() => {
                    if (
                        typeof localStorage !== "undefined" &&
                        localStorage.getItem("theme")
                    ) {
                        return localStorage.getItem("theme");
                    }
                    if (
                        window.matchMedia("(prefers-color-scheme: dark)")
                            .matches
                    ) {
                        return "dark";
                    }
                    return "light";
                })();
                if (theme === "light") {
                    document.documentElement.classList.remove("dark");
                } else {
                    document.documentElement.classList.add("dark");
                }
            };

            const setAccessibilityMode = () => {
                const accessibility = (() => {
                    if (
                        typeof localStorage !== "undefined" &&
                        localStorage.getItem("accessibility-mode")
                    ) {
                        return localStorage.getItem("accessibility-mode");
                    }
                    return "off";
                })();

                if (accessibility === "on") {
                    document.documentElement.classList.add("a11y-mode");
                } else {
                    document.documentElement.classList.remove("a11y-mode");
                }
            };

            setDarkMode();
            setAccessibilityMode();
            document.addEventListener("astro:after-swap", setDarkMode);
            document.addEventListener("astro:after-swap", setAccessibilityMode);
        </script>
    </head>
    <body class="max-w-page mx-auto min-h-screen flex flex-col">
        <nav class="px-5 py-5 flex justify-between">
            <Braces />

            <ul class="flex items-center gap-4">
                <li>
                    <a href="/" class={isOnCurrentPath("/") ? "active" : ""}
                        ><span class={isOnCurrentPath("/") ? "" : "nav-link"}
                            >Home</span
                        ></a
                    >
                </li>
                <li>
                    <a
                        href="/writing"
                        class={isOnCurrentPath("/writing") ? "active" : ""}
                        ><span
                            class={
                                isOnCurrentPath("/writing")
                                    ? ""
                                    : "nav-link"
                            }>Writing</span
                        ></a
                    >
                </li>
                <li>
                    <a
                        href="/projects"
                        class={isOnCurrentPath("/projects") ? "active" : ""}
                        ><span
                            class={
                                isOnCurrentPath("/projects")
                                    ? ""
                                    : "nav-link"
                            }>Projects</span
                        ></a
                    >
                </li>
                <li>
                    <a
                        href="/tags"
                        class={isOnCurrentPath("/tags") ? "active" : ""}
                        ><span
                            class={isOnCurrentPath("/tags") ? "" : "nav-link"}
                            >Tags</span
                        ></a
                    >
                </li>
                <li>
                    <a
                        href="/about"
                        class={isOnCurrentPath("/about") ? "active" : ""}
                        ><span
                            class={isOnCurrentPath("/about") ? "" : "nav-link"}
                            >About</span
                        ></a
                    >
                </li>
                <li>
                    <button
                        id="accessibility-toggle"
                        type="button"
                        aria-label="Toggle accessibility mode"
                        aria-pressed="false"
                        class="flex items-center"
                    >
                        <Accessibility
                            class="a11y-icon-off block"
                            size={16}
                            aria-hidden="true"
                        />
                        <X
                            class="a11y-icon-on hidden"
                            size={16}
                            aria-hidden="true"
                        />
                    </button>
                </li>
                <li>
                    <button
                        id="theme-toggle"
                        type="button"
                        aria-label="Toggle dark mode"
                        class="flex items-center"
                    >
                        <Moon class="block dark:hidden" size={16} />
                        <Sun class="hidden dark:block" size={16} />
                    </button>
                </li>
                <li>
                    <a
                        href="/feed.xml"
                        aria-label="RSS feed"
                        class="flex items-center"
                    >
                        <Rss size={16} />
                    </a>
                </li>
                <li>
                    <button
                        id="search-toggle"
                        type="button"
                        aria-label="Open search"
                        class="flex items-center"
                    >
                        <Search size={16} />
                    </button>
                </li>
            </ul>
        </nav>
        <div class="flex-1">
            <slot />
        </div>
        <footer class="px-5 py-8 mt-10 border-t border-border">
            <div
                class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 text-sm text-muted-foreground"
            >
                <p>© {new Date().getFullYear()} infinInk. Built with care.</p>
                <ul class="flex items-center gap-4">
                    <li>
                        <a href="/" class="hover:text-primary transition-colors"
                            >Home</a
                        >
                    </li>
                    <li>
                        <a
                            href="/writing"
                            class="hover:text-primary transition-colors"
                            >Writing</a
                        >
                    </li>
                    <li>
                        <a
                            href="/projects"
                            class="hover:text-primary transition-colors"
                            >Projects</a
                        >
                    </li>
                    <li>
                        <a
                            href="/tags"
                            class="hover:text-primary transition-colors"
                            >Tags</a
                        >
                    </li>
                    <li>
                        <a
                            href="/about"
                            class="hover:text-primary transition-colors"
                            >About</a
                        >
                    </li>
                    <li>
                        <a
                            href="/feed.xml"
                            class="hover:text-primary transition-colors"
                            >RSS</a
                        >
                    </li>
                </ul>
            </div>
        </footer>
        <div
            id="search-overlay"
            class="fixed inset-0 z-[100] bg-background/80 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300 flex items-start justify-center pt-20 sm:pt-32 px-4 disable-select"
            aria-hidden="true"
            inert
        >
            <div
                id="search-modal"
                class="bg-card w-full max-w-xl rounded-xl border border-border shadow-2xl scale-95 transition-transform duration-300 flex flex-col overflow-hidden max-h-[80vh]"
            >
                <div
                    class="flex items-center px-4 py-3 border-b border-border gap-3"
                >
                    <Search class="text-muted-foreground" size={18} />
                    <input
                        type="text"
                        id="search-input"
                        class="flex-1 bg-transparent border-none outline-none text-foreground placeholder:text-muted-foreground"
                        placeholder="Search posts... (Cmd+K)"
                        autocomplete="off"
                    />
                    <button
                        id="search-close"
                        class="text-xs text-muted-foreground bg-secondary px-2 py-1 rounded hidden sm:block cursor-pointer"
                        >ESC</button
                    >
                </div>
                <div
                    id="search-results"
                    class="overflow-y-auto p-3 sm:p-4 flex flex-col gap-2 hidden"
                >
                </div>
                <div
                    id="search-empty"
                    class="py-14 text-center text-sm text-muted-foreground hidden"
                >
                    No results found.
                </div>
                <div
                    id="search-initial"
                    class="px-3 sm:px-4 py-6 sm:py-7 text-sm text-muted-foreground"
                >
                    <p class="text-center">Loading recommendations...</p>
                </div>
            </div>
        </div>
        <div
            id="cursor"
            class="bg-primary mix-blend-hard-light opacity-0 size-3 rounded-full pointer-events-none z-9999 fixed top-0 left-0"
            transition:persist
        >
        </div>
        <script src="../scripts/cursor.ts"></script>
        <script>
            import type { SearchItem } from "../types";

            let onAccessibilityToggleClick: (() => void) | null = null;
            let onThemeToggleClick: ((e: MouseEvent) => void) | null = null;
            let onSearchToggleClick: ((e: MouseEvent) => void) | null = null;
            let onSearchCloseClick: ((e: MouseEvent) => void) | null = null;
            let onSearchOverlayClick: ((e: MouseEvent) => void) | null = null;
            let onSearchInitialClick: ((e: MouseEvent) => void) | null = null;
            let onSearchKeydown: ((e: KeyboardEvent) => void) | null = null;
            let onSearchInputRaw: ((e: Event) => void) | null = null;
            let searchData: SearchItem[] | null = null;

            const syncAccessibilityButtonState = () => {
                const toggle = document.getElementById("accessibility-toggle");
                if (!(toggle instanceof HTMLButtonElement)) return;

                const iconOff = toggle.querySelector(".a11y-icon-off");
                const iconOn = toggle.querySelector(".a11y-icon-on");

                const isEnabled =
                    document.documentElement.classList.contains("a11y-mode");
                toggle.setAttribute("aria-pressed", isEnabled ? "true" : "false");
                toggle.setAttribute(
                    "aria-label",
                    isEnabled
                        ? "Disable accessibility mode"
                        : "Enable accessibility mode",
                );

                if (iconOff) {
                    iconOff.classList.toggle("hidden", isEnabled);
                    iconOff.classList.toggle("block", !isEnabled);
                }
                if (iconOn) {
                    iconOn.classList.toggle("hidden", !isEnabled);
                    iconOn.classList.toggle("block", isEnabled);
                }
            };

            document.addEventListener("astro:before-swap", () => {
                const accessibilityToggle =
                    document.getElementById("accessibility-toggle");
                if (onAccessibilityToggleClick && accessibilityToggle) {
                    accessibilityToggle.removeEventListener(
                        "click",
                        onAccessibilityToggleClick,
                    );
                    onAccessibilityToggleClick = null;
                }

                const themeToggle = document.getElementById("theme-toggle");
                if (onThemeToggleClick && themeToggle) {
                    themeToggle.removeEventListener(
                        "click",
                        onThemeToggleClick,
                    );
                    onThemeToggleClick = null;
                }

                const searchToggle = document.getElementById("search-toggle");
                const searchClose = document.getElementById("search-close");
                const searchOverlay = document.getElementById("search-overlay");
                const searchInput = document.getElementById("search-input");
                const searchInitial = document.getElementById("search-initial");

                if (onSearchToggleClick && searchToggle)
                    searchToggle.removeEventListener(
                        "click",
                        onSearchToggleClick,
                    );
                if (onSearchCloseClick && searchClose)
                    searchClose.removeEventListener(
                        "click",
                        onSearchCloseClick,
                    );
                if (onSearchOverlayClick && searchOverlay)
                    searchOverlay.removeEventListener(
                        "click",
                        onSearchOverlayClick,
                    );
                if (onSearchInputRaw && searchInput)
                    searchInput.removeEventListener("input", onSearchInputRaw);
                if (onSearchInitialClick && searchInitial)
                    searchInitial.removeEventListener(
                        "click",
                        onSearchInitialClick,
                    );
                if (onSearchKeydown)
                    document.removeEventListener("keydown", onSearchKeydown);

                onSearchToggleClick = null;
                onSearchCloseClick = null;
                onSearchOverlayClick = null;
                onSearchInitialClick = null;
                onSearchInputRaw = null;
                onSearchKeydown = null;
            });

            document.addEventListener("astro:page-load", () => {
                const accessibilityToggle =
                    document.getElementById("accessibility-toggle");
                if (accessibilityToggle) {
                    syncAccessibilityButtonState();

                    onAccessibilityToggleClick = () => {
                        const isEnabled =
                            document.documentElement.classList.contains(
                                "a11y-mode",
                            );

                        if (isEnabled) {
                            document.documentElement.classList.remove(
                                "a11y-mode",
                            );
                            localStorage.setItem("accessibility-mode", "off");
                        } else {
                            document.documentElement.classList.add("a11y-mode");
                            localStorage.setItem("accessibility-mode", "on");
                        }

                        syncAccessibilityButtonState();
                    };

                    accessibilityToggle.addEventListener(
                        "click",
                        onAccessibilityToggleClick,
                    );
                }

                const themeToggle = document.getElementById("theme-toggle");
                if (themeToggle) {
                    const isDark =
                        document.documentElement.classList.contains("dark");
                    themeToggle.setAttribute(
                        "aria-pressed",
                        isDark ? "true" : "false",
                    );
                }

                onThemeToggleClick = (event: MouseEvent) => {
                    const isDark =
                        document.documentElement.classList.contains("dark");

                    const toggleTheme = () => {
                        if (isDark) {
                            document.documentElement.classList.remove("dark");
                            localStorage.setItem("theme", "light");
                            themeToggle?.setAttribute("aria-pressed", "false");
                        } else {
                            document.documentElement.classList.add("dark");
                            localStorage.setItem("theme", "dark");
                            themeToggle?.setAttribute("aria-pressed", "true");
                        }
                    };

                    const isAccessibilityMode =
                        document.documentElement.classList.contains("a11y-mode");

                    if (!document.startViewTransition || isAccessibilityMode) {
                        toggleTheme();
                        return;
                    }

                    const x = event.clientX;
                    const y = event.clientY;
                    // compute radius required to cover the entire viewport
                    // finds distance from click point to the farthest corner;
                    // hypot for calculating straight line distance
                    const endRadius = Math.hypot(
                        Math.max(x, innerWidth - x), // furthest horiz dist
                        Math.max(y, innerHeight - y), // furthest vert dist
                    );

                    document.documentElement.classList.add("theme-transition");

                    const transition = document.startViewTransition(() => {
                        toggleTheme();
                    });

                    transition.ready.then(() => {
                        const clipPath = [
                            `circle(0px at ${x}px ${y}px)`,
                            `circle(${endRadius}px at ${x}px ${y}px)`,
                        ];

                        document.documentElement.animate(
                            {
                                clipPath: clipPath,
                            },
                            {
                                duration: 500,
                                easing: "ease-in-out",
                                // targets the "new" snapshot layer created by the transition
                                pseudoElement: "::view-transition-new(root)",
                            },
                        );
                    });

                    // cleanup
                    transition.finished.finally(() => {
                        document.documentElement.classList.remove(
                            "theme-transition",
                        );
                    });
                };

                if (themeToggle) {
                    themeToggle.addEventListener("click", onThemeToggleClick);
                }

                const searchToggle = document.getElementById("search-toggle");
                const searchClose = document.getElementById("search-close");
                const searchOverlay = document.getElementById("search-overlay");
                const searchModal = document.getElementById("search-modal");
                const searchInput = document.getElementById(
                    "search-input",
                ) as HTMLInputElement;
                const resultsContainer =
                    document.getElementById("search-results");
                const emptyState = document.getElementById("search-empty");
                const initialState = document.getElementById("search-initial");

                const renderInitialRecommendations = () => {
                    if (!initialState) return;

                    if (!searchData || searchData.length === 0) {
                        initialState.innerHTML =
                            '<p class="text-center">Type to start searching.</p>';
                        return;
                    }

                    const recommended = searchData.slice(0, 5);
                    const tagFrequency = new Map<string, number>();
                    searchData.forEach((post: SearchItem) => {
                        post.tags.forEach((tag: string) => {
                            tagFrequency.set(tag, (tagFrequency.get(tag) ?? 0) + 1);
                        });
                    });
                    const recommendedTags = Array.from(tagFrequency.entries())
                        .sort((a, b) => b[1] - a[1])
                        .slice(0, 8)
                        .map(([tag]) => tag);

                    initialState.innerHTML = `
                        <div>
                            <p class="mb-3 text-xs font-medium tracking-wide uppercase text-muted-foreground">Recommended</p>
                            <div class="flex flex-col gap-1">
                                ${recommended
                                    .map(
                                        (post: SearchItem) => `
                                            <a href="${post.link}" class="flex flex-col gap-1 p-3 rounded-lg hover:bg-secondary transition-colors group">
                                                <div class="flex justify-between items-center bg-transparent">
                                                    <span class="text-foreground font-medium group-hover:text-primary transition-colors line-clamp-1">${post.title}</span>
                                                    <span class="text-xs text-muted-foreground whitespace-nowrap ml-4">${post.date}</span>
                                                </div>
                                                <span class="text-sm text-muted-foreground line-clamp-1">${post.frontmatter}</span>
                                            </a>
                                        `,
                                    )
                                    .join("")}
                            </div>
                            <div class="mt-4">
                                <p class="mb-2 text-xs font-medium tracking-wide uppercase text-muted-foreground">Recommended tags</p>
                                <div class="flex flex-wrap gap-2">
                                    ${recommendedTags
                                        .map(
                                            (tag) => `
                                                <button type="button" data-search-tag="${tag}" class="px-2 py-1 rounded-md text-xs bg-secondary text-secondary-foreground hover:bg-primary hover:text-primary-foreground transition-colors cursor-pointer">#${tag}</button>
                                            `,
                                        )
                                        .join("")}
                                </div>
                            </div>
                        </div>
                    `;
                };

                const openSearch = async () => {
                    if (!searchOverlay || !searchModal || !searchInput) return;
                    searchOverlay.removeAttribute("inert");
                    searchOverlay.setAttribute("aria-hidden", "false");
                    searchOverlay.classList.remove(
                        "opacity-0",
                        "pointer-events-none",
                    );
                    searchOverlay.classList.add("opacity-100");
                    searchModal.classList.remove("scale-95");
                    searchModal.classList.add("scale-100");
                    document.body.style.overflow = "hidden";
                    setTimeout(() => searchInput.focus(), 50);

                    if (!searchData) {
                        try {
                            const res = await fetch("/search.json");
                            searchData = await res.json();
                        } catch (e) {
                            console.error("Failed to load search index", e);
                        }
                    }

                    renderInitialRecommendations();
                    searchInput.value = "";
                    renderResults("");
                };

                const closeSearch = () => {
                    if (!searchOverlay || !searchModal) return;
                    searchOverlay.setAttribute("inert", "");
                    searchOverlay.setAttribute("aria-hidden", "true");
                    searchOverlay.classList.add(
                        "opacity-0",
                        "pointer-events-none",
                    );
                    searchOverlay.classList.remove("opacity-100");
                    searchModal.classList.add("scale-95");
                    searchModal.classList.remove("scale-100");
                    document.body.style.overflow = "";
                };

                const renderResults = (query: string) => {
                    if (!resultsContainer || !emptyState || !initialState)
                        return;
                    if (!query.trim()) {
                        resultsContainer.classList.add("hidden");
                        emptyState.classList.add("hidden");
                        initialState.classList.remove("hidden");
                        return;
                    }
                    initialState.classList.add("hidden");
                    if (!searchData) return;

                    const q = query.toLowerCase();
                    const filtered = searchData.filter(
                        (post: SearchItem) =>
                            post.title.toLowerCase().includes(q) ||
                            post.frontmatter.toLowerCase().includes(q) ||
                            post.tags.some((tag: string) =>
                                tag.toLowerCase().includes(q),
                            ),
                    );

                    if (filtered.length === 0) {
                        resultsContainer.classList.add("hidden");
                        emptyState.classList.remove("hidden");
                    } else {
                        emptyState.classList.add("hidden");
                        resultsContainer.classList.remove("hidden");

                        resultsContainer.innerHTML = filtered
                            .map(
                                (post: SearchItem) => `
                            <a href="${post.link}" class="flex flex-col gap-1 p-3 rounded-lg hover:bg-secondary transition-colors group">
                                <div class="flex justify-between items-center bg-transparent">
                                    <span class="text-foreground font-medium group-hover:text-primary transition-colors line-clamp-1">${post.title}</span>
                                    <span class="text-xs text-muted-foreground whitespace-nowrap ml-4">${post.date}</span>
                                </div>
                                <span class="text-sm text-muted-foreground line-clamp-1">${post.frontmatter}</span>
                            </a>
                        `,
                            )
                            .join("");
                    }
                };

                onSearchToggleClick = () => openSearch();
                onSearchCloseClick = () => closeSearch();
                onSearchOverlayClick = (e: MouseEvent) => {
                    if (e.target === searchOverlay) closeSearch();
                };
                onSearchInputRaw = (e: Event) => {
                    const target = e.target as HTMLInputElement;
                    renderResults(target.value);
                };
                onSearchInitialClick = (e: MouseEvent) => {
                    if (!searchInput) return;
                    const target = e.target as Element;
                    const tagButton = target.closest("[data-search-tag]");
                    if (!(tagButton instanceof HTMLButtonElement)) return;

                    const tag = tagButton.dataset.searchTag;
                    if (!tag) return;

                    searchInput.value = tag;
                    renderResults(tag);
                    searchInput.focus();
                };
                onSearchKeydown = (e: KeyboardEvent) => {
                    if ((e.metaKey || e.ctrlKey) && e.key === "k") {
                        e.preventDefault();
                        openSearch();
                    } else if (e.key === "Escape") {
                        closeSearch();
                    }
                };

                if (searchToggle)
                    searchToggle.addEventListener("click", onSearchToggleClick);
                if (searchClose)
                    searchClose.addEventListener("click", onSearchCloseClick);
                if (searchOverlay)
                    searchOverlay.addEventListener(
                        "click",
                        onSearchOverlayClick,
                    );
                if (searchInput)
                    searchInput.addEventListener("input", onSearchInputRaw);
                if (initialState)
                    initialState.addEventListener("click", onSearchInitialClick);
                document.addEventListener("keydown", onSearchKeydown);
            });
        </script>
    </body>
</html>
