---
interface Props {
    content: string;
    href?: string;
}

const { content, href } = Astro.props;
---

{
    href ? (
        <a
            href={href}
            class="text-sm text-muted-foreground rounded-full bg-muted px-3 py-1 hover:text-foreground hover:bg-accent transition-colors"
        >
            {content}
        </a>
    ) : (
        <span class="text-sm text-muted-foreground rounded-full bg-muted px-3 py-1">
            {content}
        </span>
    )
}
